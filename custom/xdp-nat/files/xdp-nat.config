config xdp-nat 'main'
	option enabled      '0'
	option wan_if       'eth1'
	option lan_if       'eth0'
	option wan_ip       ''             # WAN IPv4
	option wan_ip6      ''             # 可选：WAN IPv6（启用 NAT66）
	option lan_cidr     ''
	option queues       '1'
	option pin_cpus     '0'
	option verbose      '0'

	# NAT64 前缀（RFC 6052，默认 64:ff9b::/96；留空则禁用 NAT64）
	option nat64_prefix ''

	# NAT46 一组 v4 客户端共享的固定 IPv6 源（留空=每客户端独立合成）
	option nat46_v6_src ''

# IPv4 端口转发（可多条）：
# config forward
#	option proto    'tcp'
#	option wan_port '2222'
#	option lan_ip   '10.0.0.100'
#	option lan_port '22'

# IPv6 NPTv6 前缀转换（无状态，替代 NAT66 的轻量方案）：
# config npt6
#	option inside   'fd00:1::'
#	option outside  '2001:db8:1234::'
#	option plen     '64'

# NAT46 静态规则（v4 客户端访问 v4_target → 转成访问 v6_real）：
# config nat46
#	option v4_target '203.0.113.80'
#	option v6_real   '2001:db8::80'
